NODE_ENV=development
PORT=3000
APP_NAME=task-management-api
APP_GLOBAL_PREFIX=api
APP_SWAGGER_PATH=docs
APP_CORS_ORIGIN=http://localhost:5173
APP_ERROR_DEBUG_HEADER=x-error-debug-key
APP_ERROR_DEBUG_KEY=

DATABASE_URL=postgresql://postgres:postgres@postgres:5432/task_management?schema=public
DIRECT_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/task_management?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_USERNAME=
REDIS_PASSWORD=

JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin12345
SEED_ADMIN_FULL_NAME=System Admin

THROTTLE_TTL=60
THROTTLE_LIMIT=120
